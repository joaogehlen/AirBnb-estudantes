{
  "expo": {
    "name": "StudentNest",
    "slug": "studentnest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "studentnest",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studentnest.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Precisamos da sua localização para mostrar imóveis próximos.",
        "NSPhotoLibraryUsageDescription": "Selecione fotos do seu imóvel para anunciar.",
        "NSCameraUsageDescription": "Tire fotos do seu imóvel para anunciar."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B4F72"
      },
      "package": "com.studentnest.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#1B4F72"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Selecione fotos do seu imóvel para anunciar."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Precisamos da sua localização para mostrar imóveis próximos."
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    }
  }
}
