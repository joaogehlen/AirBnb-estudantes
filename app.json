{
  "expo": {
    "name": "StudentNest",
    "slug": "studentnest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "studentnest",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studentnest.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Precisamos da sua localização para mostrar imóveis próximos.",
        "NSPhotoLibraryUsageDescription": "Selecione fotos do seu imóvel para anunciar.",
        "NSCameraUsageDescription": "Tire fotos do seu imóvel para anunciar."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#802030"
      },
      "package": "com.studentnest.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#802030"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Selecione fotos do seu imóvel para anunciar."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Precisamos da sua localização para mostrar imóveis próximos."
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a1f3db54-9a7a-4224-88f2-8842daacc5bd"
      }
    },
    "owner": "arthurrostirolla"
  }
}
